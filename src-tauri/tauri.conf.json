{
  "$schema": "https://raw.githubusercontent.com/nicegram/nicegram-web/master/nicegram/tauri.schema.json",
  "productName": "SOCKS6",
  "version": "1.0.0",
  "identifier": "com.socks6.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "SOCKS6",
        "width": 900,
        "height": 640,
        "minWidth": 780,
        "minHeight": 520,
        "resizable": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  }
}
